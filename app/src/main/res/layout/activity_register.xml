<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"

    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical"
    tools:context=".activities.RegisterActivity">

    <LinearLayout
        android:id="@+id/LLLoadingRegister"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/gris_transparente"
        android:elevation="2dp"
        android:gravity="center"

        android:orientation="vertical"
        android:visibility="gone"
        >

        <ProgressBar
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminateTint="@color/verde_claro"

            />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.1">

            <ImageView
                android:id="@+id/IVRegresarRegister"
                android:layout_width="15dp"
                android:layout_height="15dp"

                android:layout_gravity="center_vertical"
                android:layout_marginStart="30dp"
                android:background="@drawable/flechaizquierda" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"

                android:fontFamily="@font/gothamnarrow_medium"

                android:gravity="center"
                android:text="@string/CrearCuenta"
                android:textColor="@color/black"
                android:textSize="19sp" />
        </FrameLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="0.05dp" />

        <FrameLayout
            android:id="@+id/FLRegister"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.9"
            android:paddingHorizontal="30dp">

        </FrameLayout>
    </LinearLayout>

</FrameLayout>